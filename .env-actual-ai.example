# Actual AI - Environment Configuration
# Copy this file to .env-actual-ai and fill in your Actual + OpenAI credentials.
# ACTUAL_SERVER_URL is fixed to the internal docker network address for actual-server.

ACTUAL_SERVER_URL=http://actual-server:5006
ACTUAL_PASSWORD=
ACTUAL_BUDGET_ID=

# Optional: required only if your Actual budget uses end-to-end encryption.
ACTUAL_E2E_PASSWORD=

# Run the classifier every 4 hours.
CLASSIFICATION_SCHEDULE_CRON="0 */4 * * *"

# Start in dry-run mode so you can inspect the logs before allowing writes.
# Remove "dryRun" after you are comfortable with the classifications.
FEATURES='["dryRun", "classifyOnStartup", "syncAccountsBeforeClassify"]'

LLM_PROVIDER=openai
OPENAI_API_KEY=

# Set a valid model explicitly so an empty env var does not override the app default.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional runtime tuning.
LLM_TIMEOUT_MS=120000

# Tags written into Actual notes by actual-ai.
NOT_GUESSED_TAG=#actual-ai-miss
GUESSED_TAG=#actual-ai
